@model PontoTuristicoApp.Models.PaginatedList<PontoTuristicoApp.Models.PontoTuristico>
@{
    ViewData["Title"] = "Listagem";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Pontos Turísticos</h2>
    <a asp-action="Create" class="btn btn-success">➕ Cadastrar Novo</a>
</div>

<form method="get" class="mb-4 d-flex justify-content-center">
    <input type="text" name="search" value="@ViewBag.Search" class="form-control w-50" placeholder="Buscar por nome, descrição ou localização">
    <button type="submit" class="btn btn-primary ms-3">🔍 Buscar</button>

    @if (!string.IsNullOrEmpty(ViewBag.Search))
    {
        <a asp-action="Index" class="btn btn-secondary ms-2">❌ Limpar</a>
    }
</form>


@if (!Model.Items.Any())
{
    <div class="text-center my-5">
        <h4 class="text-muted">Não encontrei nenhum resultado para a sua busca :(</h4>
    </div>
}
else
{
    <div class="row">
        @foreach (var item in Model.Items)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title fw-bold">@item.Nome</h5>
                        <h6 class="card-subtitle mb-3 text-muted">
                            📍 @item.Localizacao (@item.Cidade - @item.Estado)
                        </h6>

                        <div class="mt-auto d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary w-100">Ver Detalhes</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Editar</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Excluir</a>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav>
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" href="?search=@ViewBag.Search&page=@(Model.PageIndex - 1)">Anterior</a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link" href="?search=@ViewBag.Search&page=@i">@i</a>
                    </li>
                }

                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" href="?search=@ViewBag.Search&page=@(Model.PageIndex + 1)">Próximo</a>
                </li>
            </ul>
        </nav>
    }
}
